{
  "info": {
    "name": "SSMS API",
    "description": "Silkworm Smart Management System — Django REST API. Import this collection and the SSMS_Local environment to get started.\n\nAll responses use the envelope: { success, message, data }.\nAll keys are camelCase.\nAuth: Bearer JWT in Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/",
              "host": ["{{base_url}}"],
              "path": ["health", ""]
            },
            "description": "Verify the server is running. No auth required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success is true', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
